{
  "name": "el-kheima",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "vue-tsc && vite build",
    "type-check": "vue-tsc --noEmit",
    "validate:i18n": "node scripts/validate-i18n.mjs",
    "test:unit": "vitest run",
    "test:a11y": "vitest run src/__tests__/a11y",
    "test:frontend": "node scripts/validate-i18n.mjs && vitest run"
  },
  "dependencies": {
    "@resort-os/core": "workspace:*",
    "@resort-os/ui": "workspace:*",
    "axios": "^1.6.0",
    "pinia": "^2.1.0",
    "qrcode": "1.5.4",
    "vue": "^3.4.0",
    "vue-i18n": "^9.9.1",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/qrcode": "1.5.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "2.4.6",
    "autoprefixer": "^10.4.0",
    "axe-core": "4.10.3",
    "jsdom": "24.1.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "1.6.1",
    "vue-tsc": "^2.0.0"
  }
}
