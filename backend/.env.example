# Core
DATABASE_URL=postgresql+psycopg://postgres:resort_dev_pass@localhost:5436/resort_os
SECRET_KEY=CHANGE_ME_minimum_32_characters_here_xxxxxx
ENVIRONMENT=development

# Resort
RESORT_NAME=El Kheima Beach
DEFAULT_CURRENCY=EGP
VAT_PERCENTAGE=14.0
SERVICE_CHARGE_PERCENTAGE=12.0
TIMEZONE=Africa/Cairo

# API
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5175

# Infrastructure
REDIS_URL=redis://localhost:6381/0
CELERY_BROKER_URL=redis://localhost:6381/1
CELERY_RESULT_BACKEND=redis://localhost:6381/2

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30
# Require a valid TOTP code at /login for 2FA-enabled accounts (real second
# factor). Turn on together with a frontend that submits the code at login.
LOGIN_2FA_ENFORCED=false

# IP-keyed rate limit on POST /auth/login and /auth/register (app.core.rate_limit).
# 5/300s is the production-recommended default — do not raise it in production.
# A local dev environment switching between many demo accounts quickly can
# raise these safely (this file is just documentation of the default; each
# environment's own .env controls its actual value).
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Security — مفتاحان منفصلان
SURVEY_TOKEN_SECRET=CHANGE_ME_survey_secret_min_32_chars_xxxx
FIELD_ENCRYPTION_KEY=

# Public guest site — لبناء روابط /order, /survey, /beach/checkin المُرسَلة
# فعليًا للضيف عبر واتساب (بدون / في الآخر، مثال: https://alkhaymaresort.com)
PUBLIC_SITE_URL=

# WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=

# Payments
PAYMOB_API_KEY=
PAYMOB_CARD_INTEGRATION_ID=
PAYMOB_VODAFONE_INTEGRATION_ID=

# E-Invoice Egypt (ETA) — sandbox: https://id.preprod.eta.gov.eg
ETA_ENABLED=false
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=
ETA_TAXPAYER_RIN=
ETA_TAXPAYER_NAME=
ETA_BRANCH_CODE=0

# Storage
FILE_STORAGE_PATH=uploads
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
# ADMIN_PHONE is read by app.core.kernel.whatsapp.notify_admin() — used for
# low-stock/overdue/payroll-reminder alerts and (wagdy.md T-03) Celery task
# failure notifications.
ADMIN_PHONE=

# Offsite backup sync (wagdy.md T-04) — scripts/backup_db.sh, optional. See
# that script's header comment for full details. Requires rclone installed
# + configured (`rclone config`) with a remote matching the name before the
# colon in BACKUP_RCLONE_REMOTE (e.g. `b2` in `b2:bucket/path`).
BACKUP_REMOTE_ENABLED=false
BACKUP_RCLONE_REMOTE=
BACKUP_RCLONE_CONFIG=
