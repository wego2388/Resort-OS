# ─────────────────────────────────────────────────────────────────────────────
#  Resort OS (El Kheima Beach) — root .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend: Python ───────────────────────────────────────────────────────────
backend/.venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd
**/*.egg-info/
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/.coverage.*
backend/celerybeat-schedule
*.sqlite3
backend/test.db
backend/uploads/

# ── Backend: secrets / local env ──────────────────────────────────────────────
# Real secrets live in backend/.env — never commit it.
# backend/.env.example is a template with no real secrets and MUST stay tracked.
backend/.env
!backend/.env.example

# ── Frontend: Node / pnpm monorepo ────────────────────────────────────────────
**/node_modules/
**/dist/
frontend/apps/*/dist/
**/.vite/
*.tsbuildinfo

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ── OS / Editor cruft ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Misc local artifacts ───────────────────────────────────────────────────────
# scripts/start.sh|stop.sh|status.sh write real PID files + logs here (moved
# off /tmp to a project-local, per-run location — 2026-07-04 scripts/ reorg).
.pids/
backend/logs/
backups/
